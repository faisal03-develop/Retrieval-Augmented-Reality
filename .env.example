OPENAI_API_KEY=your_openai_api_key_here

# Use local embeddings (run: python -m scripts.download_models)
USE_LOCAL_EMBEDDINGS=true
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
LOCAL_EMBEDDING_PATH=models/embeddings/bge-small-en-v1.5

# Embedding model (OpenAI, used when USE_LOCAL_EMBEDDINGS=false)
EMBEDDING_MODEL=text-embedding-3-small

# Chat model
CHAT_MODEL=gpt-4o-mini

# Paths
DOCUMENTS_DIR=data/documents
VECTOR_STORE_DIR=storage/vector_store
